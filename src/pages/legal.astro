<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="no-referrer" />
  <title>Mentions légales — Caribbean Countdowns</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0f0f0f;
      color: #e0e0e0;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .page { max-width: 860px; margin: 0 auto; padding: 48px 24px 80px; }

    .header-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .site-title {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #fff;
    }

    .lang-group {
      display: flex;
      gap: 4px;
      flex-shrink: 0;
    }

    .lang-btn {
      background: transparent;
      border: 1px solid #555;
      border-radius: 3px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.8px;
      padding: 4px 10px;
      color: #aaa;
      font-family: inherit;
      transition: all 0.15s;
    }
    .lang-btn:hover { border-color: #888; color: #eee; }
    .lang-btn.active { background: #1e3a5f; border-color: #2d6aa0; color: #7ec8e3; }

    .back-link { font-size: 12px; color: #555; text-decoration: underline; }
    .back-link:hover { color: #999; }

    .divider { border: none; border-top: 1px solid #2e2e2e; margin: 28px 0; }

    h2 {
      font-size: 15px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    p { color: #888; margin-bottom: 10px; font-size: 13px; }

    .section { margin-bottom: 8px; }

    .badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 3px;
      background: #0d2a2a;
      color: #34d399;
      border: 1px solid #065f46;
      margin-bottom: 16px;
    }
  </style>
</head>

<body>
  <div class="page">

