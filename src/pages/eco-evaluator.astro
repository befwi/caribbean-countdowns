---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Eco Evaluator — Caribbean Countdowns</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0a0f0f;
      color: #e0e0e0;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }

    .page { max-width: 860px; margin: 0 auto; padding: 40px 24px 80px; }

    .back-link {
      display: inline-block;
      font-size: 12px;
      color: #555;
      text-decoration: none;
      margin-bottom: 28px;
      letter-spacing: 0.3px;
    }
    .back-link:hover { color: #888; }

    .top-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 28px;
      gap: 16px;
    }

    h1 { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
    .subtitle { font-size: 13px; color: #666; }

    .lang-group { display: flex; gap: 4px; flex-shrink: 0; }
    .lang-btn {
      background: transparent;
      border: 1px solid #333;
      border-radius: 3px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.8px;
      padding: 4px 10px;
      color: #666;
      font-family: inherit;
      transition: all 0.15s;
    }
    .lang-btn:hover { border-color: #888; color: #eee; }
    .lang-btn.active { background: #0d2a2a; border-color: #0d9488; color: #5eead4; }

    .score-panel {
      display: flex;
      align-items: center;
      gap: 24px;
      background: #0d1a1a;
      border: 1px solid #1a3030;
      border-radius: 8px;
      padding: 20px 24px;
      margin-bottom: 32px;
    }

    .grade-circle {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      border: 3px solid;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      font-weight: 800;
      line-height: 1;
      flex-shrink: 0;
      transition: all 0.2s;
    }
    .grade-score-sub { font-size: 10px; font-weight: 600; margin-top: 2px; opacity: 0.8; }

    .grade-A { color: #4ade80; background: #0d2a0d; border-color: #166534; }
    .grade-B { color: #a3e635; background: #1a2a08; border-color: #365314; }
    .grade-C { color: #facc15; background: #2a1f00; border-color: #78350f; }
    .grade-D { color: #fb923c; background: #2a1200; border-color: #7c2d12; }
    .grade-F { color: #f87171; background: #2a0000; border-color: #7f1d1d; }

    .score-details { flex: 1; }
    .score-number { font-size: 32px; font-weight: 700; line-height: 1; }
    .score-label { font-size: 12px; color: #666; margin-top: 2px; }
    .score-progress {
      margin-top: 10px;
      height: 6px;
      background: #1a2a2a;
      border-radius: 3px;
      overflow: hidden;
    }
    .score-progress-fill {
      height: 100%;
      background: #0d9488;
      border-radius: 3px;
      transition: width 0.3s;
    }

    .grade-legend {
      display: flex;
      flex-direction: column;
      gap: 3px;
      font-size: 11px;
      color: #555;
    }
    .legend-row { display: flex; gap: 6px; align-items: center; }
    .legend-pip {
      width: 18px;
      text-align: center;
      font-weight: 700;
      font-size: 10px;
      padding: 1px 4px;
      border-radius: 2px;
    }
    .pip-A { color: #4ade80; background: #0d2a0d; }
    .pip-B { color: #a3e635; background: #1a2a08; }
    .pip-C { color: #facc15; background: #2a1f00; }
    .pip-D { color: #fb923c; background: #2a1200; }
    .pip-F { color: #f87171; background: #2a0000; }

    .category { margin-bottom: 28px; }

    .category-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 1px solid #1a2a2a;
    }
    .category-icon { font-size: 16px; }
    .category-name { font-size: 14px; font-weight: 700; flex: 1; }
    .category-tally {
      font-size: 12px;
      color: #555;
      font-family: 'Courier New', monospace;
    }
    .cat-bar-track {
      width: 80px;
      height: 4px;
      background: #1a2a2a;
      border-radius: 2px;
      overflow: hidden;
    }
    .cat-bar-fill {
      height: 100%;
      background: #0d9488;
      border-radius: 2px;
      transition: width 0.2s;
    }

    .criterion {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid #0f1e1e;
      cursor: pointer;
    }
    .criterion:last-child { border-bottom: none; }
    .criterion:hover { background: #0d1515; margin: 0 -8px; padding-left: 8px; padding-right: 8px; border-radius: 4px; }

    .criterion input[type="checkbox"] {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      margin-top: 2px;
      accent-color: #0d9488;
      cursor: pointer;
    }

    .criterion-body { flex: 1; }
    .criterion-label { font-size: 13px; color: #ccc; margin-bottom: 2px; }
    .criterion-tip { font-size: 11px; color: #555; line-height: 1.4; }

    .criterion.checked .criterion-label { color: #5eead4; }

    .reset-row {
      margin-top: 32px;
      padding-top: 20px;
      border-top: 1px solid #1a2a2a;
      text-align: right;
    }

    .reset-btn {
      background: transparent;
      border: 1px solid #2a1a1a;
      border-radius: 4px;
      color: #555;
      cursor: pointer;
      font-family: inherit;
      font-size: 12px;
      padding: 5px 14px;
      transition: all 0.15s;
    }
    .reset-btn:hover { border-color: #555; color: #888; }
  </style>
</head>
<body>
<div class="page">

  <a class="back-link" href="/">← Caribbean Countdowns</a>

  <div class="top-row">
    <div>
      <h1>♻️ Eco Evaluator</h1>
      <p class="subtitle" id="ui-subtitle"></p>
    </div>
    <div class="lang-group">
      <button class="lang-btn active" data-lang="en">EN</button>
      <button class="lang-btn" data-lang="fr">FR</button>
      <button class="lang-btn" data-lang="kr">KR</button>
      <button class="lang-btn" data-lang="es">ES</button>
    </div>
  </div>

  <div class="score-panel">
    <div class="grade-circle grade-F" id="grade-circle">
      F
      <span class="grade-score-sub" id="grade-score-sub">0/100</span>
    </div>
    <div class="score-details">
      <div class="score-number"><span id="score-number">0</span><span style="font-size:16px;color:#444">/100</span></div>
      <div class="score-label" id="ui-score-label"></div>
      <div class="score-progress"><div class="score-progress-fill" id="score-bar" style="width:0%"></div></div>
    </div>
    <div class="grade-legend">
      <div class="legend-row"><span class="legend-pip pip-A">A</span> <span id="ui-grade-A"></span></div>
      <div class="legend-row"><span class="legend-pip pip-B">B</span> <span id="ui-grade-B"></span></div>
      <div class="legend-row"><span class="legend-pip pip-C">C</span> <span id="ui-grade-C"></span></div>
      <div class="legend-row"><span class="legend-pip pip-D">D</span> <span id="ui-grade-D"></span></div>
      <div class="legend-row"><span class="legend-pip pip-F">F</span> 0–19 —</div>
    </div>
  </div>

  <div id="criteria-form"></div>

  <div class="reset-row">
    <button class="reset-btn" id="reset-btn"></button>
  </div>

</div>

<script is:inline src="/scripts/eco-evaluator.js" defer></script>
</body>
</html>
