---
// import festivals2025 from "../data/festivals-2025.json";
import festivals2026 from "../data/festivals-2026.json";
import festivals2027 from "../data/festivals-2027.json";
import sponsors from "../data/sponsors.json";

// const festivals = [...festivals2025, ...festivals2026];
const festivals = [...festivals2026, ...festivals2027];
import FestivalRow from "../components/FestivalRow.astro";

const now = new Date();

function getStatus(f) {
  const start = new Date(f.startDate + "T00:00:00");
  const end = new Date(f.endDate + "T23:59:59");
  if (now > end) return "ENDED";
  if (now >= start) return "LIVE";
  return "UPCOMING";
}

const enriched = festivals
  .map(f => ({ ...f, status: getStatus(f) }))
  .sort((a, b) => {
    if (a.status === "ENDED" && b.status !== "ENDED") return 1;
    if (a.status !== "ENDED" && b.status === "ENDED") return -1;
    return new Date(a.startDate).getTime() - new Date(b.startDate).getTime();
  });

const eventTypes = ["All", "music festival", "carnival", "regatta", "other"];
const eventTypeLabels: Record<string, Record<string, string>> = {
  "All":           { en: "All types",          fr: "Tous les types",      kr: "Tout kalité",        es: "Todos los tipos" },
  "music festival":{ en: "music festival",      fr: "festival de musique", kr: "mizik fèstival",     es: "festival de música" },
  "carnival":      { en: "carnival",            fr: "carnaval",            kr: "kanaval",            es: "carnaval" },
  "regatta":       { en: "regatta",             fr: "régate",              kr: "kous bato",             es: "regata" },
  "other":         { en: "other",               fr: "autre",               kr: "le restan",                es: "otro" },
};

const vibes = ["All", ...Array.from(new Set(festivals.flatMap(f => f.vibes ?? []).filter(v => v)))];
const countries = ["All", ...Array.from(new Set(festivals.map(f => f.country).filter(Boolean)))];

const lastUpdateEn = new Date().toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
const lastUpdateFr = new Date().toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
const lastUpdateEs = new Date().toLocaleDateString("es-ES", { day: "numeric", month: "long", year: "numeric" });

const liveFestivals = enriched.filter(f => f.status === "LIVE");

const { ngo, sponsor } = sponsors;

function splitLines(text: string) {
  return text.split(";").map(s => s.trim()).filter(Boolean);
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="no-referrer" />
  <title>Caribbean Countdowns</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0f0f0f;
      color: #e0e0e0;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .page { max-width: 860px; margin: 0 auto; padding: 48px 24px 80px; }

    .header-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .site-title {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.3px;
      color: #fff;
    }

    .site-subtitle {
      font-size: 13px;
      color: #fff;
      margin-bottom: 32px;
    }

    /* Language buttons */
    .lang-group {
      display: flex;
      gap: 4px;
      flex-shrink: 0;
    }

    .lang-btn {
      background: transparent;
      border: 1px solid #555;
      border-radius: 3px;
      cursor: pointer;
      font-size: 18px;
      letter-spacing: 0;
      padding: 2px 6px;
      color: #aaa;
      font-family: inherit;
      transition: all 0.15s;
      opacity: 0.5;
    }

    .lang-btn:hover { border-color: #888; opacity: 0.8; }

    .lang-btn.active {
      background: #1a1a1a;
      border-color: #555;
      opacity: 1;
    }

    /* Filters */
    .filter-group { margin-bottom: 10px; }
    .filter-group:last-of-type { margin-bottom: 28px; }

    .filters { display: flex; flex-wrap: wrap; gap: 8px; }

    .filter-tag {
      cursor: pointer;
      padding: 4px 12px;
      border-radius: 3px;
      border: 1px solid #333;
      background: transparent;
      color: #999;
      font-size: 12px;
      font-family: inherit;
      transition: all 0.15s;
      user-select: none;
    }

    .filter-tag:hover { border-color: #555; color: #ccc; }

    .filter-tag.active {
      background: #1e3a5f;
      border-color: #2d6aa0;
      color: #7ec8e3;
    }

    /* Live banner */
    .live-banner {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #1a0a0a;
      border: 1px solid #3a1010;
      border-radius: 4px;
      padding: 10px 16px;
      margin-bottom: 32px;
      font-size: 13px;
      color: #f87171;
    }

    .live-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #ef4444;
      animation: pulse 1.4s infinite;
      flex-shrink: 0;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .divider { border: none; border-top: 1px solid #2e2e2e; margin: 0; }

    .info-bar {
      font-size: 12px;
      color: #555;
      margin-bottom: 28px;
      display: flex;
      flex-wrap: wrap;
      gap: 6px 0;
      flex-direction: column;
    }

    .info-bar a { color: #555; text-decoration: underline; }
    .info-bar a:hover { color: #999; }

    .criteria-toggle { color: #444; cursor: pointer; list-style: none; }
    .criteria-toggle:hover { color: #777; }
    .criteria-toggle::marker { display: none; }
    details[open] .criteria-toggle { color: #666; }
    .criteria-list {
      margin-top: 6px;
      padding: 10px 14px;
      border-left: 2px solid #2e2e2e;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .criteria-list span { color: #444; font-size: 11px; }
    .criteria-list strong { color: #555; }


    /* Sponsor band */
    .sponsor-footer {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #0a1a18;
      border: 1px solid #0d3d35;
      border-radius: 4px;
      padding: 10px 16px;
      margin-bottom: 32px;
      font-size: 13px;
      color: #5eead4;
    }

    .sponsor-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #14b8a6;
      flex-shrink: 0;
    }

    .sponsor-cause {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      flex: 1;
    }

    .sponsor-cause-text {
      font-size: 13px;
      color: #5eead4;
      flex: 1;
    }

    .sponsor-cause-text a { color: #5eead4; text-decoration: underline; }
    .sponsor-cause-text a:hover { color: #99f6e4; }

    .sponsor-cta {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 3px;
      border: 1px solid #0d9488;
      color: #5eead4;
      background: #0a1a18;
      text-decoration: none;
      transition: background 0.15s;
      white-space: nowrap;
    }
    .sponsor-cta:hover { background: #134e4a; color: #99f6e4; text-decoration: none; }

    .sponsor-logos {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    @media (max-width: 600px) {
      .sponsor-cause {
        flex-direction: column;
        align-items: center;
        gap: 10px;
        text-align: center;
      }
      .sponsor-cause-text {
        font-size: 12px;
        flex: unset;
        width: 100%;
        text-align: center;
      }
      .sponsor-cta {
        padding: 5px 16px;
        font-size: 12px;
      }
    }

  </style>
</head>

<body>
  <div class="page">

    <div class="header-row">
      <h1 class="site-title">Caribbean Countdowns</h1>
      <div class="lang-group">
        <button class="lang-btn" data-lang="en" onclick="setLang('en')" title="English">🇬🇧</button>
        <button class="lang-btn" data-lang="kr" onclick="setLang('kr')" title="Kréyol">🇭🇹</button>
        <button class="lang-btn" data-lang="fr" onclick="setLang('fr')" title="Français">🇫🇷</button>
        <button class="lang-btn" data-lang="es" onclick="setLang('es')" title="Español">🇪🇸</button>
      </div>
    </div>

    <p class="site-subtitle">
      <span class="t-en">Live countdowns to music festivals and cultural events across the Caribbean.</span>
      <span class="t-fr">Compte à rebours des événements à venir de la Caraïbe — festivals, carnavals, régates...</span>
      <span class="t-kr">Kont a rébò pou festival mizik épi gro évènman an Karayib la.</span>
      <span class="t-es">Cuenta regresiva de festivales de música y eventos en el Caribe.</span>
    </p>

    <div class="info-bar">
      <span>
        <span class="t-en">To add/update a festival, <a href="https://github.com/befwi/caribbean-countdowns/pulls" target="_blank" rel="noopener noreferrer">send in a pull request</a>.</span>
        <span class="t-fr">Pour ajouter/modifier un festival, <a href="https://github.com/befwi/caribbean-countdowns/pulls" target="_blank" rel="noopener noreferrer">faire une pull request</a>.</span>
        <span class="t-kr">Pou mété an lòt fèstival, <a href="https://github.com/befwi/caribbean-countdowns/pulls" target="_blank" rel="noopener noreferrer">voyé an pull request</a>.</span>
        <span class="t-es">Para agregar/actualizar un festival, <a href="https://github.com/befwi/caribbean-countdowns/pulls" target="_blank" rel="noopener noreferrer">envía un pull request</a>.</span>
      </span>
      <span>
        <span class="t-en">Last update: {lastUpdateEn}</span>
        <span class="t-fr">Dernière mise à jour : {lastUpdateFr}</span>
        <span class="t-kr">Dènyé mizajou : {lastUpdateFr}</span>
        <span class="t-es">Última actualización: {lastUpdateEs}</span>
      </span>
      <details>
        <summary class="criteria-toggle">
          <span class="t-en">▸ Click here to see the listing criteria for listed events</span>
          <span class="t-fr">▸ Cliquez ici pour connaître les critères de sélection des événements listés</span>
          <span class="t-kr">▸ Klikez la pou wè kritè séleksyon évènman listé yo</span>
          <span class="t-es">▸ Haz clic aquí para ver los criterios de selección de los eventos listados</span>
        </summary>
        <div class="criteria-list">
          <span>
            <span class="t-en">An event is listed if it meets <strong>at least 2 of these 3 criteria:</strong></span>
            <span class="t-fr">Un événement est listé s'il remplit <strong>au moins 2 de ces 3 critères :</strong></span>
            <span class="t-kr">On évènman listé si li rempli <strong>omwen 2 nan 3 kritè sa yo :</strong></span>
            <span class="t-es">Un evento se lista si cumple <strong>al menos 2 de estos 3 criterios:</strong></span>
          </span>
          <span>
            <span class="t-en">① <strong>Recurring</strong> — minimum 2nd edition (events in their first edition are not listed)</span>
            <span class="t-fr">① <strong>Récurrence</strong> — minimum 2ème édition (les événements à leur 1ère édition ne sont pas listés)</span>
            <span class="t-kr">① <strong>Récidiv</strong> — minimòm 2yèm édisyon (évènman ki an 1yer édisyon pa listé)</span>
            <span class="t-es">① <strong>Recurrencia</strong> — mínimo 2ª edición (los eventos en su 1ª edición no se listan)</span>
          </span>
          <span>
            <span class="t-en">② <strong>Public ticketing</strong> — tickets on sale via an external platform, or free public entry</span>
            <span class="t-fr">② <strong>Billetterie publique</strong> — billets en vente sur une plateforme externe, ou entrée gratuite ouverte à tous</span>
            <span class="t-kr">② <strong>Biléteri piblik</strong> — tikè an vant sou platfòm ekstèn, oswa antrée gratis pou tout moun</span>
            <span class="t-es">② <strong>Taquilla pública</strong> — entradas en venta en plataforma externa, o entrada gratuita abierta al público</span>
          </span>
          <span>
            <span class="t-en">③ <strong>Lineup</strong> — minimum 3 distinct artists or acts publicly announced</span>
            <span class="t-fr">③ <strong>Programmation</strong> — minimum 3 artistes ou actes distincts annoncés publiquement</span>
            <span class="t-kr">③ <strong>Pwogramasyon</strong> — minimòm 3 atis oswa akò distinkt anoonsé piblikman</span>
            <span class="t-es">③ <strong>Cartel</strong> — mínimo 3 artistas o actos distintos anunciados públicamente</span>
          </span>
        </div>
      </details>
    </div>

    <!-- Sponsor band -->
    <div class="sponsor-footer">
      <div class="sponsor-cause">
        <span class="sponsor-cause-text">
          <span class="t-en">This site supports the NGO <a href={ngo.website} target="_blank" rel="noopener noreferrer">{ngo.name}</a><br />Thanks to our sponsor <a href={sponsor.website} target="_blank" rel="noopener noreferrer">{sponsor.name}</a></span>
          <span class="t-fr">Ce site soutient l'ONG <a href={ngo.website} target="_blank" rel="noopener noreferrer">{ngo.name}</a><br />Merci à notre sponsor <a href={sponsor.website} target="_blank" rel="noopener noreferrer">{sponsor.name}</a></span>
          <span class="t-kr">Sit sa a sipòté ONG <a href={ngo.website} target="_blank" rel="noopener noreferrer">{ngo.name}</a><br />Mèsi bay sponsor nou <a href={sponsor.website} target="_blank" rel="noopener noreferrer">{sponsor.name}</a></span>
          <span class="t-es">Este sitio apoya a la ONG <a href={ngo.website} target="_blank" rel="noopener noreferrer">{ngo.name}</a><br />Gracias a nuestro sponsor <a href={sponsor.website} target="_blank" rel="noopener noreferrer">{sponsor.name}</a></span>
        </span>
        <div class="sponsor-logos">
          <a href={ngo.website} target="_blank" rel="noopener noreferrer">
            <img src={ngo.logo} alt={ngo.name} style="height:36px;vertical-align:middle;border-radius:4px;background:#fff;padding:3px 7px;" />
          </a>
          <a href={sponsor.website} target="_blank" rel="noopener noreferrer">
            <img src={sponsor.logo} alt={sponsor.name} style="height:36px;vertical-align:middle;border-radius:4px;background:#fff;padding:3px 7px;" />
          </a>
        </div>
        <a class="sponsor-cta" href="/sponsor/">
          <span class="t-en">Become a sponsor</span>
          <span class="t-fr">Devenir sponsor</span>
          <span class="t-kr">Vin yon sponsor</span>
          <span class="t-es">Ser patrocinador</span>
        </a>
      </div>
    </div>

    <!-- Live banner -->
    {liveFestivals.length > 0 && (
      <div class="live-banner">
        <span class="live-dot"></span>
        <span>
          <span class="t-en">{liveFestivals.map((f, i) => <><strong style="text-shadow: 0 0 10px rgba(239,68,68,0.7), 0 0 20px rgba(239,68,68,0.3); text-decoration: underline;">{i > 0 ? ", " : ""}{f.name}</strong></>)}{liveFestivals.length === 1 ? " is" : " are"} happening now.</span>
          <span class="t-fr">{liveFestivals.length === 1 ? "L'évènement " : "Les évènements "}{liveFestivals.map((f, i) => <><strong style="text-shadow: 0 0 10px rgba(239,68,68,0.7), 0 0 20px rgba(239,68,68,0.3); text-decoration: underline;">{i > 0 ? ", " : ""}{f.name}</strong></>)}{liveFestivals.length === 1 ? " est" : " sont"} en cours.</span>
          <span class="t-kr">{liveFestivals.map((f, i) => <><strong style="text-shadow: 0 0 10px rgba(239,68,68,0.7), 0 0 20px rgba(239,68,68,0.3); text-decoration: underline;">{i > 0 ? ", " : ""}{f.name}</strong></>)} ka fèt a lè la.</span>
          <span class="t-es">{liveFestivals.map((f, i) => <><strong style="text-shadow: 0 0 10px rgba(239,68,68,0.7), 0 0 20px rgba(239,68,68,0.3); text-decoration: underline;">{i > 0 ? ", " : ""}{f.name}</strong></>)}{liveFestivals.length === 1 ? " está" : " están"} pasando ahora.</span>
        </span>
      </div>
    )}

    <!-- Filters -->
    <div class="filter-group">
      <div class="filters">
        {eventTypes.map(t => (
          <button class={`filter-tag${t === "All" ? " active" : ""}`} data-filter-type="type" data-value={t}>
            <span class="t-en">{eventTypeLabels[t].en}</span>
            <span class="t-fr">{eventTypeLabels[t].fr}</span>
            <span class="t-kr">{eventTypeLabels[t].kr}</span>
            <span class="t-es">{eventTypeLabels[t].es}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="filter-group">
      <div class="filters">
        {vibes.map(g => (
          <button class={`filter-tag${g === "All" ? " active" : ""}`} data-filter-type="vibe" data-value={g}>
            <span class="t-en">{g === "All" ? "All vibes" : g}</span>
            <span class="t-fr">{g === "All" ? "Toutes les vibes" : g}</span>
            <span class="t-kr">{g === "All" ? "Tout vibe" : g}</span>
            <span class="t-es">{g === "All" ? "Todos los vibes" : g}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="filter-group">
      <div class="filters">
        {countries.map(c => (
          <button class={`filter-tag${c === "All" ? " active" : ""}`} data-filter-type="country" data-value={c}>
            <span class="t-en">{c === "All" ? "All countries" : c}</span>
            <span class="t-fr">{c === "All" ? "Tous les pays" : c}</span>
            <span class="t-kr">{c === "All" ? "Tout péyi" : c}</span>
            <span class="t-es">{c === "All" ? "Todos los países" : c}</span>
          </button>
        ))}
      </div>
    </div>

    <hr class="divider" />

    <!-- Festival list -->
    {enriched.map(festival => (
      <FestivalRow festival={festival} />
    ))}

    <div style="text-align:center;padding:32px 0 8px;">
      <!-- Option A : visitor-badge.laobi.icu (actif) -->
      <img src="https://visitor-badge.laobi.icu/badge?page_id=befwi.caribbean-countdowns" alt="visitor count" style="height:18px;opacity:0.5;" />
      <!-- Option B : hits.seeyoufarm.com -->
      {/* <img src="https://hits.seeyoufarm.com/api/count/incr/badge.svg?url=https%3A%2F%2Fcaribbean-countdowns.com&count_bg=%23333333&title_bg=%23111111&title=visitors&edge_flat=true" alt="visitor count" style="height:18px;opacity:0.5;" /> */}
    </div>

    <div style="text-align:center;padding:0 0 16px;font-size:11px;">
      <a href="/legal/" style="color:#333;text-decoration:underline;">
        <span class="t-en">Legal notice</span>
        <span class="t-fr">Mentions légales</span>
        <span class="t-kr">Mention légal</span>
        <span class="t-es">Aviso legal</span>
      </a>
      &nbsp;·&nbsp;
      <a href="/sponsor/" style="color:#333;text-decoration:underline;">
        <span class="t-en">Become a sponsor</span>
        <span class="t-fr">Devenir sponsor</span>
        <span class="t-kr">Vin yon sponsor</span>
        <span class="t-es">Ser patrocinador</span>
      </a>
    </div>

  </div>

<div id="extToast" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1a1a1a;border:1px solid #333;border-radius:4px;padding:8px 16px;font-size:12px;color:#999;pointer-events:none;white-space:nowrap;z-index:100;"></div>

  <script is:inline>
    var LANGS = ["en", "fr", "kr", "es"];
    var lang = localStorage.getItem("lang") || "en";

    function applyLang() {
      LANGS.forEach(function(l) {
        document.querySelectorAll(".t-" + l).forEach(function(el) {
          el.style.display = l === lang ? "" : "none";
        });
      });
      document.documentElement.lang = lang;
      document.querySelectorAll(".lang-btn").forEach(function(btn) {
        btn.classList.toggle("active", btn.getAttribute("data-lang") === lang);
      });
    }

    function setLang(l) {
      lang = l;
      localStorage.setItem("lang", lang);
      applyLang();
    }

    applyLang();

    // External link toast
    var toastTimer;
    var toastMsgs = {
      en: "You are leaving Caribbean Countdowns",
      fr: "Vous quittez Caribbean Countdowns",
      kr: "Ou ka kité Caribbean Countdowns",
      es: "Estás saliendo de Caribbean Countdowns"
    };

    function showToast() {
      var toast = document.getElementById("extToast");
      if (!toast) return;
      toast.textContent = toastMsgs[lang] || toastMsgs.en;
      toast.style.display = "block";
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function() { toast.style.display = "none"; }, 3000);
    }

    window.onclick = function(e) {
      var el = e.target;
      while (el && el !== document.body) {
        if (el.tagName === "A" && el.target === "_blank") {
          showToast();
          return;
        }
        el = el.parentElement;
      }
    };

    // Countdowns
    function format(ms) {
      if (ms <= 0) return "—";
      var s = Math.floor(ms / 1000);
      var d = Math.floor(s / 86400);
      var h = Math.floor((s % 86400) / 3600);
      var m = Math.floor((s % 3600) / 60);
      var sec = s % 60;
      var unit = (lang === "fr" || lang === "kr") ? "j" : (lang === "es" ? "d" : "d");
      return d + unit + " " + h + "h " + m + "m " + sec + "s";
    }

    function updateCountdowns() {
      document.querySelectorAll(".countdown[data-date]").forEach(function(el) {
        var target = Number(el.getAttribute("data-date"));
        if (!target) return;
        var diff = target - Date.now();
        el.textContent = format(diff);
      });
    }

    updateCountdowns();
    setInterval(updateCountdowns, 1000);

    // Filters
    var activeType = "All";
    var activeVibe = "All";
    var activeCountry = "All";

    function applyFilters() {
      document.querySelectorAll(".festival-entry").forEach(function(row) {
        var rowType = row.getAttribute("data-type") || "";
        var rowVibes = (row.getAttribute("data-vibes") || "").split(",");
        var rowCountry = row.getAttribute("data-country") || "";
        var matchType = activeType === "All" || rowType === activeType;
        var matchVibe = activeVibe === "All" || rowVibes.indexOf(activeVibe) !== -1;
        var matchCountry = activeCountry === "All" || rowCountry === activeCountry;
        var show = matchType && matchVibe && matchCountry;
        row.style.display = show ? "" : "none";
        var next = row.nextElementSibling;
        if (next && next.classList.contains("divider")) {
          next.style.display = show ? "" : "none";
        }
      });
    }

    document.querySelectorAll(".filter-tag").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var type = btn.getAttribute("data-filter-type");
        var value = btn.getAttribute("data-value");
        document.querySelectorAll(".filter-tag[data-filter-type='" + type + "']").forEach(function(b) {
          b.classList.remove("active");
        });
        btn.classList.add("active");
        if (type === "type") activeType = value;
        if (type === "vibe") activeVibe = value;
        if (type === "country") activeCountry = value;
        applyFilters();
      });
    });
  </script>
</body>
</html>
